# Service Flow frontend — env template
# Copy to .env (or .env.local) and fill in. .env files are gitignored.
# Production values live in Vercel dashboard env vars.

REACT_APP_API_URL=http://localhost:3001/api

# Google OAuth client ID (public-by-design)
REACT_APP_GOOGLE_CLIENT_ID=

# Google Maps API key — referrer-restricted to your domains in GCP
REACT_APP_GOOGLE_MAPS_API_KEY=

# Stripe publishable key (pk_test_ in dev). Required at build time.
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# Optional: only needed if any code reads the NEXT_PUBLIC_ prefix
NEXT_PUBLIC_GOOGLE_API_KEY=

# Set to "production" in Vercel production target. Leave blank locally.
REACT_APP_ENV=
